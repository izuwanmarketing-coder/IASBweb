{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "droply",
  "compatibility_date": "2026-07-14",
  "routes": [
    {
      "pattern": "droply.izuwanautomobile.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
